---
import Button from './Button.astro';
import { site } from '../data/site';

/**
 * Sticky header (04-ANIMATION-SPEC §8):
 * top = ±78px, wit; na scroll = ±64px, blur + subtiele border.
 */
const links = [
  { href: '#oplossingen', label: 'Oplossingen' },
  { href: '#voor-wie', label: 'Voor wie' },
  { href: '#werkwijze', label: 'Werkwijze' },
  { href: '#projecten', label: 'Projecten' },
  { href: '#over', label: 'Over CE-iT' },
  { href: '#contact', label: 'Contact' },
];
---

<header
  id="site-header"
  class="sticky top-0 z-50 border-b border-transparent bg-white transition-all duration-200"
>
  <nav
    class="mx-auto flex h-[78px] w-full max-w-6xl items-center justify-between gap-6 px-6 transition-[height] duration-200"
    aria-label="Hoofdnavigatie"
  >
    <a href="#top" class="flex items-center" aria-label="CE-iT — naar boven">
      <img
        src={`${import.meta.env.BASE_URL}images/logo/ce-it-logo-wordmark.png`}
        alt="CE-iT"
        class="h-7 w-auto md:h-8"
        width="2000"
        height="625"
        loading="eager"
        decoding="async"
      />
    </a>

    <ul class="hidden items-center gap-6 lg:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-[15px] text-ink-600 transition-colors hover:text-brand-600"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-3">
      <Button href="#contact" size="sm" class="hidden sm:inline-flex">
        Plan een gesprek
      </Button>
      <button
        id="menu-toggle"
        type="button"
        class="flex h-10 w-10 items-center justify-center rounded-md border border-line lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Menu openen"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 18 18"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          class="text-ink-800"
          aria-hidden="true"
        >
          <path class="menu-open" d="M2 5h14M2 9h14M2 13h14"></path>
          <path class="menu-close hidden" d="M4 4l10 10M14 4L4 14"></path>
        </svg>
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="hidden border-t border-line bg-white px-6 pb-6 pt-3 lg:hidden"
  >
    <ul class="space-y-1">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="block rounded-md px-3 py-2.5 text-[16px] text-ink-800 hover:bg-paper-50 hover:text-brand-600"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
    <div class="mt-4 px-3">
      <Button href="#contact" class="w-full">Plan een gesprek</Button>
    </div>
  </div>
</header>

<style>
  /* Gescrold: compacter + blur + border (via JS-klasse .scrolled) */
  #site-header.scrolled {
    border-color: var(--color-line);
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }
  #site-header.scrolled nav {
    height: 64px;
  }
  @media (prefers-reduced-motion: reduce) {
    #site-header,
    #site-header nav {
      transition: none;
    }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const onScroll = () => {
    header?.classList.toggle('scrolled', window.scrollY > 8);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Mobiel menu
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const openIcon = toggle?.querySelector('.menu-open');
  const closeIcon = toggle?.querySelector('.menu-close');

  const setOpen = (open: boolean) => {
    menu?.classList.toggle('hidden', !open);
    toggle?.setAttribute('aria-expanded', String(open));
    toggle?.setAttribute('aria-label', open ? 'Menu sluiten' : 'Menu openen');
    openIcon?.classList.toggle('hidden', open);
    closeIcon?.classList.toggle('hidden', !open);
  };

  toggle?.addEventListener('click', () => {
    setOpen(menu?.classList.contains('hidden') ?? false);
  });
  // Sluit menu na klik op een link
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => setOpen(false))
  );
</script>
