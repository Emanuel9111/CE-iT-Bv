---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../sections/Hero.astro';
import Audience from '../sections/Audience.astro';
import Process from '../sections/Process.astro';
// Services is opgegaan in het gecombineerde UniFi-blok (Wat we doen +
// technologie) — één verhaal, geen herhaling.
import UniFi from '../sections/UniFi.astro';
// Projecten staat UIT tot er échte projecten met échte foto's zijn —
// een lege/valse portfolio schaadt meer dan geen portfolio.
// Aanzetten: import + <Projects /> hieronder terugzetten, en de
// 'Projecten'-links in Header.astro en Footer.astro herstellen.
// import Projects from '../sections/Projects.astro';
import Nieuwbouw from '../sections/Nieuwbouw.astro';
import About from '../sections/About.astro';
import ContactCta from '../sections/ContactCta.astro';
import Contact from '../sections/Contact.astro';
---

<Base>
  <Header />
  <main>
    <Hero />
    <Audience />
    <Process />
    <UniFi />
    <Nieuwbouw />
    <About />
    <ContactCta />
    <Contact />
  </main>
  <Footer />
</Base>
