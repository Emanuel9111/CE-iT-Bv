---
import fs from 'node:fs';
import path from 'node:path';
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';
import { asset } from '../utils/paths';

/**
 * Twee grote keuzeblokken met foto + overlay (referentiestijl).
 * Foto's verschijnen automatisch zodra de bestanden in /public/images/ staan.
 */
const audienceData = [
  {
    title: 'Studentenhuisvesting',
    benefit: 'Stabiele wifi op elke verdieping en in elke kamer.',
    cta: 'Bekijk oplossing',
    file: 'studentenhuisvesting-hero.jpg',
    alt: 'Studentenresidentie waar CE-iT het netwerk beheert',
    icon: '<svg viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M11 3 2 7.5 11 12l9-4.5L11 3Z"/><path d="M6 9.7V14c0 1.4 2.2 2.7 5 2.7s5-1.3 5-2.7V9.7"/></svg>',
  },
  {
    title: 'KMO’s & bedrijven',
    benefit: 'Een professioneel netwerk waarop uw bedrijf kan vertrouwen.',
    cta: 'Bekijk oplossing',
    file: 'kmo-hero.jpg',
    alt: 'Professioneel kantoor met netwerk van CE-iT',
    icon: '<svg viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="7" width="14" height="10" rx="2"/><path d="M8 7V5.5A1.5 1.5 0 0 1 9.5 4h3A1.5 1.5 0 0 1 14 5.5V7"/></svg>',
  },
];

const audiences = audienceData.map((a) => ({
  ...a,
  exists: fs.existsSync(path.join(process.cwd(), 'public', 'images', a.file)),
  src: asset(`images/${a.file}`),
}));
---

<Section id="voor-wie" tone="paper">
  <div class="reveal max-w-3xl">
    <Eyebrow>Oplossingen per omgeving</Eyebrow>
    <h2
      class="mt-3 font-display text-[28px] font-semibold leading-tight tracking-tight text-ink-950 md:text-[34px]"
    >
      Voor wie werken we?
    </h2>
  </div>

  <div class="mt-8 grid gap-7 md:grid-cols-2">
    {
      audiences.map((audience) => (
        <a
          href="#contact"
          class="reveal group relative block overflow-hidden rounded-xl border border-line"
          style="aspect-ratio: 16/7.5;"
        >
          {/* Foto-laag (of plaatshouder tot het bestand er is) */}
          <div class="absolute inset-0 transition-transform duration-300 ease-out group-hover:scale-[1.025]">
            {audience.exists ? (
              <img
                src={audience.src}
                alt={audience.alt}
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover"
              />
            ) : (
              <span class="flex h-full w-full items-center justify-center bg-paper-100 px-6 text-center font-mono text-[12px] text-ink-500">
                [ECHTE FOTO &rarr; /images/{audience.file}]
              </span>
            )}
          </div>
          {/* Overlay — verdiept subtiel bij hover */}
          <div
            class="absolute inset-0 bg-gradient-to-t from-ink-950/85 via-ink-950/25 to-transparent"
            aria-hidden="true"
          />
          <div
            class="absolute inset-0 bg-gradient-to-t from-ink-950/60 via-ink-950/10 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"
            aria-hidden="true"
          />
          {/* Inhoud */}
          <div class="absolute inset-x-0 bottom-0 p-5 md:p-6">
            <span
              class="mb-2.5 flex h-10 w-10 items-center justify-center rounded-lg bg-brand-600 p-2.5 text-white"
              aria-hidden="true"
              set:html={audience.icon}
            />
            <h3 class="font-display text-[21px] font-semibold tracking-tight text-white">
              {audience.title}
            </h3>
            <p class="mt-1 max-w-sm text-[14px] leading-snug text-white/85">
              {audience.benefit}
            </p>
            <p class="mt-3 inline-flex items-center gap-2 text-[14px] font-medium text-white">
              <span class="bg-gradient-to-r from-white to-white bg-[length:0%_1px] bg-left-bottom bg-no-repeat transition-[background-size] duration-300 group-hover:bg-[length:100%_1px]">
                {audience.cta}
              </span>
              <span
                class="transition-transform duration-200 group-hover:translate-x-[3px]"
                aria-hidden="true"
              >
                &rarr;
              </span>
            </p>
          </div>
        </a>
      ))
    }
  </div>
</Section>
