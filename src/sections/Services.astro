---
import fs from 'node:fs';
import path from 'node:path';
import Eyebrow from '../components/Eyebrow.astro';
import { asset } from '../utils/paths';

/**
 * Drie hoofdservices als compacte kolommen (design brief §7E).
 * Kleine onderpadding: deze sectie loopt visueel door in de
 * UniFi-band eronder (de technologie achter de services).
 * Foto's verschijnen automatisch zodra de bestanden in /public/images/
 * staan; tot dan géén zichtbare plaatshouder (productie-schoon).
 * Geen "meer over"-links: die pagina's bestaan (nog) niet.
 */
const serviceData = [
  {
    title: 'Netwerk & wifi',
    text: 'Professioneel ontworpen wifi- en netwerkoplossingen voor gebouwen waar bereik, stabiliteit en schaalbaarheid belangrijk zijn.',
    file: 'service-netwerk-wifi.jpg',
  },
  {
    title: 'Bekabeling & installatie',
    text: 'Van patchkast tot werkplek, kamer of verdieping. We leggen een betrouwbare basis met nette en professionele bekabeling.',
    file: 'service-bekabeling.jpg',
  },
  {
    title: 'Beheer & monitoring',
    text: 'We houden uw netwerk in het oog, voeren updates uit en grijpen in wanneer dat nodig is.',
    file: 'service-beheer.jpg',
  },
];

const services = serviceData.map((s) => ({
  ...s,
  exists: fs.existsSync(path.join(process.cwd(), 'public', 'images', s.file)),
  src: asset(`images/${s.file}`),
}));
---

<section id="oplossingen" class="bg-white">
  <div class="mx-auto w-full max-w-6xl px-6 pb-10 pt-12 md:pb-12 md:pt-16">
    <div class="reveal max-w-3xl">
      <Eyebrow>Wat we doen</Eyebrow>
      <h2
        class="mt-3 font-display text-[28px] font-semibold leading-tight tracking-tight text-ink-950 md:text-[34px]"
      >
        Van eerste kabel tot dagelijks beheer.
      </h2>
    </div>

    <div class="mt-8 grid gap-8 md:grid-cols-3 md:gap-6">
      {
        services.map((service) => (
          <div class="reveal">
            {service.exists && (
              <img
                src={service.src}
                alt={`${service.title} door CE-iT`}
                loading="lazy"
                decoding="async"
                class="mb-4 aspect-[16/10] w-full rounded-lg object-cover"
              />
            )}
            <h3 class="font-display text-[18px] font-semibold tracking-tight text-ink-950">
              {service.title}
            </h3>
            <p class="mt-2 text-[13.5px] leading-relaxed text-ink-600">
              {service.text}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
