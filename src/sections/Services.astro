---
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';
import SmartImage from '../components/SmartImage.astro';

/** Drie hoofdservices — geen tien kleine kaarten (design brief §7E).
 *  Foto's verschijnen automatisch zodra de bestanden in /public/images/ staan. */
const services = [
  {
    title: 'Netwerk & wifi',
    text: 'Professioneel ontworpen wifi- en netwerkoplossingen voor gebouwen waar bereik, stabiliteit en schaalbaarheid belangrijk zijn.',
    cta: 'Meer over netwerk & wifi',
    file: 'service-netwerk-wifi.jpg',
    label: 'AP-installatie / wifi in gebouw',
  },
  {
    title: 'Bekabeling & installatie',
    text: 'Van patchkast tot werkplek, kamer of verdieping. We leggen een betrouwbare basis met nette en professionele bekabeling.',
    cta: 'Meer over bekabeling',
    file: 'service-bekabeling.jpg',
    label: 'nette bekabeling / patchkast',
  },
  {
    title: 'Beheer & monitoring',
    text: 'We houden uw netwerk in het oog, voeren updates uit en grijpen in wanneer dat nodig is.',
    cta: 'Meer over beheer',
    file: 'service-beheer.jpg',
    label: 'monitoring dashboard',
  },
];
---

<Section id="oplossingen">
  <div class="reveal max-w-3xl">
    <Eyebrow>Wat we doen</Eyebrow>
    <h2
      class="mt-3 font-display text-[28px] font-semibold leading-tight tracking-tight text-ink-950 md:text-[34px]"
    >
      Van eerste kabel tot dagelijks beheer.
    </h2>
  </div>

  <div class="mt-8 space-y-10 md:space-y-12">
    {
      services.map((service, i) => (
        <div
          class={`reveal grid items-center gap-6 md:grid-cols-2 md:gap-12 ${
            i % 2 === 1 ? 'md:[&>*:first-child]:order-2' : ''
          }`}
        >
          <SmartImage
            file={service.file}
            label={service.label}
            alt={`${service.title} door CE-iT`}
            aspect="16/9"
            class="w-full md:max-w-[440px] md:justify-self-center"
          />
          <div>
            <h3 class="font-display text-[24px] font-semibold tracking-tight text-ink-950">
              {service.title}
            </h3>
            <p class="mt-3 max-w-md text-[16px] leading-relaxed text-ink-600">
              {service.text}
            </p>
            <a
              href="#contact"
              class="group mt-4 inline-flex items-center gap-2 text-[15px] font-medium text-brand-600 hover:text-brand-500"
            >
              {service.cta}
              <span
                class="transition-transform duration-200 group-hover:translate-x-[3px]"
                aria-hidden="true"
              >
                &rarr;
              </span>
            </a>
          </div>
        </div>
      ))
    }
  </div>
</Section>
