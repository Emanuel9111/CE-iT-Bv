---
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';
import PlaceholderImage from '../components/PlaceholderImage.astro';

/** Drie hoofdservices — geen tien kleine kaarten (design brief §7E). */
const services = [
  {
    title: 'Netwerk & wifi',
    text: 'Professioneel ontworpen wifi- en netwerkoplossingen voor gebouwen waar bereik, stabiliteit en schaalbaarheid belangrijk zijn.',
    cta: 'Meer over netwerk & wifi',
    image: 'AP-installatie / wifi in gebouw',
  },
  {
    title: 'Bekabeling & installatie',
    text: 'Van patchkast tot werkplek, kamer of verdieping. We leggen een betrouwbare basis met nette en professionele bekabeling.',
    cta: 'Meer over bekabeling',
    image: 'nette bekabeling / patchkast',
  },
  {
    title: 'Beheer & monitoring',
    text: 'We houden uw netwerk in het oog, voeren updates uit en grijpen in wanneer dat nodig is.',
    cta: 'Meer over beheer',
    image: 'monitoring dashboard',
  },
];
---

<Section id="oplossingen">
  <div class="reveal max-w-3xl">
    <Eyebrow>Wat we doen</Eyebrow>
    <h2
      class="mt-5 font-display text-[28px] font-semibold leading-tight tracking-tight text-ink-950 md:text-[34px]"
    >
      Van eerste kabel tot dagelijks beheer.
    </h2>
  </div>

  <div class="mt-14 space-y-16 md:space-y-20">
    {
      services.map((service, i) => (
        <div
          class={`reveal grid items-center gap-8 md:grid-cols-2 md:gap-14 ${
            i % 2 === 1 ? 'md:[&>*:first-child]:order-2' : ''
          }`}
        >
          <PlaceholderImage label={service.image} aspect="16/10" />
          <div>
            <h3 class="font-display text-[24px] font-semibold tracking-tight text-ink-950">
              {service.title}
            </h3>
            <p class="mt-4 max-w-md text-[16px] leading-relaxed text-ink-600">
              {service.text}
            </p>
            <a
              href="#contact"
              class="group mt-6 inline-flex items-center gap-2 text-[15px] font-medium text-teal-600 hover:text-teal-500"
            >
              {service.cta}
              <span
                class="transition-transform duration-200 group-hover:translate-x-[3px]"
                aria-hidden="true"
              >
                &rarr;
              </span>
            </a>
          </div>
        </div>
      ))
    }
  </div>
</Section>
