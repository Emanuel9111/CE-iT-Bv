---
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';

/** Compacte band (geen volledige sectie) — zie feedbackronde 3. */
---

<section class="border-y border-line bg-white">
  <div
    class="mx-auto flex w-full max-w-6xl flex-col gap-5 px-6 py-10 md:flex-row md:items-center md:justify-between md:gap-10"
  >
    <div class="reveal max-w-2xl">
      <Eyebrow>Vanaf de eerste kabel goed</Eyebrow>
      <h2
        class="mt-2 font-display text-[22px] font-semibold leading-tight tracking-tight text-ink-950 md:text-[26px]"
      >
        Nieuwbouw of renovatie? Bouw het netwerk meteen correct op.
      </h2>
      <p class="mt-2 text-[14.5px] leading-relaxed text-ink-600">
        Bij nieuwbouw en renovatie denken we mee over bekabeling, technische
        ruimtes, patchkasten en de plaatsing van access points. Zo is het
        netwerk klaar voor vandaag én voor later.
      </p>
    </div>
    <div class="reveal shrink-0">
      <Button href="#contact" variant="secondary" arrow>
        Bespreek uw project
      </Button>
    </div>
  </div>
</section>
