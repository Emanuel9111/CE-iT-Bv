---
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';
---

<Section>
  <div class="reveal max-w-3xl">
    <Eyebrow>Vanaf de eerste kabel goed</Eyebrow>
    <h2
      class="mt-5 font-display text-[28px] font-semibold leading-tight tracking-tight text-ink-950 md:text-[34px]"
    >
      Nieuwbouw of renovatie? Bouw het netwerk meteen correct op.
    </h2>
    <p class="mt-6 text-[16px] leading-relaxed text-ink-600">
      Een betrouwbaar netwerk begint bij de infrastructuur. Bij nieuwbouw en
      renovatie denken we mee over bekabeling, technische ruimtes,
      patchkasten en de plaatsing van access points. Zo is het netwerk klaar
      voor vandaag én voor later.
    </p>
    <div class="mt-8">
      <Button href="#contact" variant="secondary" arrow>
        Bespreek uw project
      </Button>
    </div>
  </div>
</Section>
