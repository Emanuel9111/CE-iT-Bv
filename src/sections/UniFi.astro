---
import fs from 'node:fs';
import path from 'node:path';
import Eyebrow from '../components/Eyebrow.astro';
import SmartImage from '../components/SmartImage.astro';
import { asset } from '../utils/paths';

/**
 * Gecombineerd blok "Wat we doen + de technologie erachter" (dark).
 * Voorheen twee aparte secties (Services + UniFi) — samengevoegd om
 * herhaling te vermijden: de eerste helft van de pagina legt uit,
 * dit blok vat samen en bewijst (feedbackronde 4).
 * Servicefoto's verschijnen pas wanneer de bestanden bestaan.
 */
const serviceData = [
  {
    title: 'Netwerk & wifi',
    text: 'Professioneel ontworpen wifi- en netwerkoplossingen voor gebouwen waar bereik, stabiliteit en schaalbaarheid belangrijk zijn.',
    file: 'service-netwerk-wifi.jpg',
  },
  {
    title: 'Bekabeling & installatie',
    text: 'Van patchkast tot werkplek, kamer of verdieping. We leggen een betrouwbare basis met nette en professionele bekabeling.',
    file: 'service-bekabeling.jpg',
  },
  {
    title: 'Beheer & monitoring',
    text: 'We houden uw netwerk in het oog, voeren updates uit en grijpen in wanneer dat nodig is.',
    file: 'service-beheer.jpg',
    // brede monitoring-foto: laptop als focuspunt in de 16/10-crop
    pos: '58% 50%',
  },
];

const services = serviceData.map((s) => ({
  ...s,
  exists: fs.existsSync(path.join(process.cwd(), 'public', 'images', s.file)),
  src: asset(`images/${s.file}`),
}));

const products = [
  { label: 'Cloud Gateway', file: 'unifi-gateway.png' },
  { label: 'Professional Switches', file: 'unifi-switch.png' },
  { label: 'Access Points', file: 'unifi-ap.png' },
];
---

<section id="oplossingen" class="bg-dark-950 text-paper-100">
  <div class="mx-auto w-full max-w-6xl px-6 py-14 md:py-16">
    <div class="reveal max-w-3xl">
      <Eyebrow tone="dark">Wat we doen</Eyebrow>
      <h2
        class="mt-3 font-display text-[28px] font-semibold leading-tight tracking-tight text-white md:text-[34px]"
      >
        Van eerste kabel tot dagelijks beheer.
      </h2>
    </div>

    <!-- Drie services, compact -->
    <div class="mt-8 grid gap-8 md:grid-cols-3 md:gap-6">
      {
        services.map((service) => (
          <div class="reveal">
            {service.exists && (
              <img
                src={service.src}
                alt={`${service.title} door CE-iT`}
                loading="lazy"
                decoding="async"
                class="mb-4 aspect-[16/10] w-full rounded-lg object-cover"
                style={service.pos ? `object-position: ${service.pos}` : undefined}
              />
            )}
            <h3 class="font-display text-[17px] font-semibold tracking-tight text-white">
              {service.title}
            </h3>
            <p class="mt-2 text-[13.5px] leading-relaxed text-paper-100/70">
              {service.text}
            </p>
          </div>
        ))
      }
    </div>

    <!-- De technologie erachter -->
    <div class="mt-10 border-t border-dark-line pt-8">
      <div
        class="reveal flex flex-wrap items-baseline justify-between gap-x-8 gap-y-2"
      >
        <h3
          class="font-display text-[19px] font-semibold tracking-tight text-white"
        >
          Gebouwd op UniFi technologie
        </h3>
        <p class="font-mono text-[12px] leading-relaxed text-brand-100/70">
          Gateway &rarr; Switches &rarr; Bekabeling &rarr; Access Points
          &rarr; Gebruikers
        </p>
      </div>
      <p
        class="reveal mt-3 max-w-2xl text-[14px] leading-relaxed text-paper-100/70"
      >
        CE-iT werkt met de betrouwbare en schaalbare netwerkoplossingen van
        Ubiquiti UniFi. Krachtige hardware, centraal beheer en monitoring op
        afstand — klaar voor de toekomst.
      </p>

      <div id="unifi-products" class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-3">
        {
          products.map((product, i) => (
            <figure class="unifi-product" style={`--i: ${i}`}>
              <SmartImage
                file={product.file}
                kind="product"
                label={product.label}
                alt={`UniFi ${product.label}`}
                aspect="4/3"
                tone="dark"
              />
              <figcaption class="mt-3 text-center font-mono text-[12px] text-paper-100/70">
                {product.label}
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  /* Producten verschijnen gefaseerd bij scroll-in (04-ANIMATION-SPEC §6) */
  html.js .unifi-product {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.45s ease-out,
      transform 0.45s ease-out;
    transition-delay: calc(var(--i) * 0.15s);
  }
  #unifi-products.active .unifi-product {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: reduce) {
    html.js .unifi-product {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const grid = document.getElementById('unifi-products');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (grid) {
    if (reduced || !('IntersectionObserver' in window)) {
      grid.classList.add('active');
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              grid.classList.add('active');
              io.disconnect();
            }
          }
        },
        { threshold: 0.3 }
      );
      io.observe(grid);
    }
  }
</script>
