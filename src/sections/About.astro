---
import fs from 'node:fs';
import path from 'node:path';
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';
import { asset } from '../utils/paths';
import { site } from '../data/site';

/**
 * Over CE-iT. Productie-schoon: de zin met jaren/regio en de foto
 * verschijnen pas wanneer de echte gegevens/het echte beeld er zijn
 * (src/data/site.ts + /public/images/emanuel-terrein.jpg).
 */
const photoExists = fs.existsSync(
  path.join(process.cwd(), 'public', 'images', 'emanuel-terrein.jpg')
);
const photoSrc = asset('images/emanuel-terrein.jpg');
const hasExperienceLine = Boolean(site.yearsExperience || site.region);
---

<Section id="over" tone="paper">
  <div
    class={`grid items-start gap-12 ${photoExists ? 'md:grid-cols-[3fr_2fr] md:gap-14' : ''}`}
  >
    <div class="reveal max-w-3xl">
      <Eyebrow>Lokaal en technisch betrokken</Eyebrow>
      <h2
        class="mt-3 font-display text-[28px] font-semibold leading-tight tracking-tight text-ink-950 md:text-[34px]"
      >
        Geen callcenter. Eén partner die uw netwerk kent.
      </h2>
      <p class="mt-4 text-[16px] leading-relaxed text-ink-600">
        CE-iT combineert praktijkervaring in glasvezel, bekabeling en
        netwerkinfrastructuur met moderne netwerkoplossingen. We werken
        lokaal, communiceren direct en blijven betrokken nadat de installatie
        is afgerond.
      </p>
      {
        hasExperienceLine && (
          <p class="mt-4 text-[16px] leading-relaxed text-ink-600">
            {site.yearsExperience &&
              `${site.yearsExperience} jaar terreinervaring op het Belgische FTTH-net`}
            {site.yearsExperience && site.region && ', '}
            {site.region && `actief in ${site.region}`}.
          </p>
        )
      }
    </div>

    {
      photoExists && (
        <div class="reveal">
          <img
            src={photoSrc}
            alt="Emanuel Costescu van CE-iT aan het werk op locatie"
            loading="lazy"
            decoding="async"
            class="aspect-[4/5] w-full rounded-lg object-cover"
          />
        </div>
      )
    }
  </div>
</Section>
