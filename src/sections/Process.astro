---
/**
 * "Zo bouwen wij uw netwerk" — premium proces-animatie (tweede signature
 * na de hero). Per stap een micro-animatie die de stap uitlegt:
 * scan → kabel-tekening → LED-boot → wifi-ripples → dashboard-sweep.
 * Speelt één keer bij scroll-in; op mobiel is alle content altijd
 * zichtbaar (opacity 1) en worden de effecten vereenvoudigd.
 * Bron: CEIT-process-animation-pack, aangepast op de site-tokens.
 */
import { asset } from '../utils/paths';

const steps = [
  {
    number: '01',
    key: 'analyse',
    title: 'Analyse',
    text: 'We bekijken uw gebouw, uw infrastructuur en wat uw gebruikers nodig hebben.',
    image: 'images/step-analyse.png',
    alt: 'Analyse van een gebouw en de bestaande infrastructuur',
    status: 'Analyse uitgevoerd',
  },
  {
    number: '02',
    key: 'bekabeling',
    title: 'Bekabeling',
    text: 'Professionele structurele bekabeling op de juiste plaatsen, in elke ruimte.',
    image: 'images/step-bekabeling.png',
    alt: 'Structurele bekabeling die door een gebouw naar de patchkast loopt',
    status: 'Bekabeling geoptimaliseerd',
  },
  {
    number: '03',
    key: 'apparatuur',
    title: 'Apparatuur',
    text: 'We installeren en configureren gateway, switches en netwerkcomponenten.',
    image: 'images/step-apparatuur.png',
    alt: 'Professionele netwerkswitch',
    status: 'Apparatuur actief',
  },
  {
    number: '04',
    key: 'wifi',
    title: 'Wifi',
    text: 'Access points op de juiste plaatsen voor stabiele en consistente dekking.',
    image: 'images/step-wifi.png',
    alt: 'Access point met wifi-dekking aan een plafond',
    status: 'Dekking geactiveerd',
  },
  {
    number: '05',
    key: 'beheer',
    title: 'Beheer',
    text: 'We monitoren en beheren het netwerk op afstand en volgen snel op.',
    image: 'images/service-beheer.jpg',
    alt: 'Laptop met UniFi-dashboard voor netwerkbeheer, met serverrack op de achtergrond',
    status: 'Netwerk online · Beheerd door CE-iT',
  },
];
---

<section
  id="werkwijze"
  class="process-premium"
  data-process-premium
  aria-labelledby="process-premium-title"
>
  <div class="process-premium__inner">
    <div class="process-premium__heading">
      <p class="process-premium__eyebrow">Van analyse tot beheer</p>
      <h2 id="process-premium-title">Zo bouwen wij uw netwerk.</h2>
      <p>Eén duidelijk proces. Eén partner voor het volledige netwerk.</p>
    </div>

    <div class="process-premium__timeline" aria-hidden="true">
      <div class="process-premium__track"></div>
      <div class="process-premium__progress" data-process-progress></div>
      <span class="process-premium__data-pulse" data-process-pulse></span>
    </div>

    <div class="process-premium__grid">
      {
        steps.map((step, index) => (
          <article
            class={`process-step process-step--${step.key}`}
            data-process-step
            data-index={index}
          >
            <div class="process-step__head">
              <span class="process-step__number">{step.number}</span>
              <div>
                <h3>{step.title}</h3>
                <p>{step.text}</p>
              </div>
            </div>

            <div class="process-step__media">
              <img
                src={asset(step.image)}
                alt={step.alt}
                loading={index < 2 ? 'eager' : 'lazy'}
                decoding="async"
              />

              {step.key === 'analyse' && (
                <div class="fx fx--analyse" aria-hidden="true">
                  <span class="fx-scan" />
                  <span class="fx-target fx-target--one" />
                  <span class="fx-target fx-target--two" />
                </div>
              )}

              {step.key === 'bekabeling' && (
                <svg
                  class="fx fx--cable"
                  viewBox="0 0 100 72"
                  preserveAspectRatio="none"
                  aria-hidden="true"
                >
                  <path
                    class="cable-shadow"
                    d="M11 66 C24 61 24 46 38 46 S52 28 62 28 S72 14 90 10"
                  />
                  <path
                    class="cable-line"
                    d="M11 66 C24 61 24 46 38 46 S52 28 62 28 S72 14 90 10"
                  />
                </svg>
              )}

              {step.key === 'apparatuur' && (
                <div class="fx fx--apparatuur" aria-hidden="true">
                  <span class="led led--1" />
                  <span class="led led--2" />
                  <span class="led led--3" />
                  <span class="led led--4" />
                  <span class="led led--5" />
                  <span class="led led--6" />
                </div>
              )}

              {step.key === 'wifi' && (
                <div class="fx fx--wifi" aria-hidden="true">
                  <span class="wifi-ring wifi-ring--1" />
                  <span class="wifi-ring wifi-ring--2" />
                  <span class="wifi-ring wifi-ring--3" />
                </div>
              )}

              {step.key === 'beheer' && (
                <div class="fx fx--beheer" aria-hidden="true">
                  <span class="screen-sweep" />
                  <span class="online-dot" />
                </div>
              )}
            </div>

            <p class="process-step__status">
              <span />
              {step.status}
            </p>
          </article>
        ))
      }
    </div>

    <p class="process-premium__final" data-process-final>
      Van eerste analyse tot dagelijks beheer.{' '}
      <strong>Eén partner voor het volledige netwerk.</strong>
    </p>
  </div>
</section>

<script>
  const section = document.querySelector('[data-process-premium]');

  if (section) {
    const steps = Array.from(section.querySelectorAll('[data-process-step]'));
    const progress = section.querySelector<HTMLElement>(
      '[data-process-progress]'
    );
    const pulse = section.querySelector('[data-process-pulse]');
    const finalMessage = section.querySelector('[data-process-final]');
    const reducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;
    let hasPlayed = false;

    const activateAll = () => {
      steps.forEach((step) => step.classList.add('is-active'));
      progress?.style.setProperty('--progress', '100%');
      pulse?.classList.add('is-active');
      finalMessage?.classList.add('is-visible');
    };

    const play = () => {
      if (hasPlayed) return;
      hasPlayed = true;

      if (reducedMotion) {
        activateAll();
        return;
      }

      steps.forEach((step, index) => {
        window.setTimeout(() => {
          step.classList.add('is-active');
          const pct =
            steps.length === 1 ? 100 : (index / (steps.length - 1)) * 100;
          progress?.style.setProperty('--progress', `${pct}%`);

          if (index === steps.length - 1) {
            window.setTimeout(() => {
              pulse?.classList.add('is-active');
              finalMessage?.classList.add('is-visible');
            }, 500);
          }
        }, index * 1000);
      });
    };

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          if (entries.some((entry) => entry.isIntersecting)) {
            play();
            observer.disconnect();
          }
        },
        { threshold: 0.15 }
      );
      observer.observe(section);
    } else {
      activateAll();
    }
  }
</script>

<style>
  .process-premium {
    --brand: #4e98c6;
    --brand-strong: #367daa;
    --ink: #0f1922;
    --muted: #647480;
    --line: #d8e5ed;
    background: #fff;
    overflow: clip;
  }

  .process-premium__inner {
    width: min(1152px, calc(100% - 48px));
    margin: 0 auto;
    padding: 56px 0 64px;
  }

  .process-premium__heading {
    max-width: 660px;
    margin-bottom: 30px;
  }
  .process-premium__eyebrow {
    margin: 0 0 12px;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--brand-strong);
  }
  .process-premium h2 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(28px, 3.4vw, 34px);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .process-premium__heading > p:last-child {
    margin: 12px 0 0;
    color: var(--muted);
    font-size: 16px;
  }

  .process-premium__timeline {
    position: relative;
    height: 3px;
    margin: 0 7.5% 24px;
  }
  .process-premium__track,
  .process-premium__progress {
    position: absolute;
    inset: 0;
    border-radius: 999px;
  }
  .process-premium__track {
    background: var(--line);
  }
  .process-premium__progress {
    --progress: 0%;
    width: var(--progress);
    right: auto;
    background: linear-gradient(90deg, var(--brand-strong), #72b9e5);
    box-shadow: 0 0 18px rgba(78, 152, 198, 0.3);
    transition: width 650ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .process-premium__data-pulse {
    position: absolute;
    top: 50%;
    left: 0;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: white;
    box-shadow:
      0 0 0 3px rgba(78, 152, 198, 0.3),
      0 0 16px rgba(78, 152, 198, 0.9);
    opacity: 0;
    transform: translate(-50%, -50%);
  }
  .process-premium__data-pulse.is-active {
    opacity: 1;
    animation: dataPulse 2.8s ease-in-out 1;
  }

  .process-premium__grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 18px;
  }
  .process-step {
    min-width: 0;
    opacity: 0.54;
    transform: translateY(12px);
    transition:
      opacity 0.55s ease,
      transform 0.55s ease;
  }
  .process-step.is-active {
    opacity: 1;
    transform: translateY(0);
  }
  .process-step__head {
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 11px;
    align-items: start;
    min-height: 142px;
  }
  .process-step__number {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 999px;
    border: 1px solid rgba(78, 152, 198, 0.5);
    font-family: var(--font-mono);
    color: var(--brand-strong);
    font-size: 12px;
    font-weight: 500;
    transition:
      color 0.35s ease,
      background 0.35s ease,
      box-shadow 0.35s ease,
      transform 0.35s ease;
  }
  .process-step.is-active .process-step__number {
    color: white;
    background: var(--brand);
    box-shadow: 0 8px 24px rgba(78, 152, 198, 0.22);
    transform: scale(1.04);
  }
  .process-step h3 {
    margin: 5px 0 7px;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--ink);
    font-size: 17px;
  }
  .process-step__head p {
    margin: 0;
    color: var(--muted);
    font-size: 13.5px;
    line-height: 1.55;
  }

  .process-step__media {
    position: relative;
    aspect-ratio: 4 / 3;
    border: 1px solid #d8e4eb;
    border-radius: 12px;
    background: #f8fbfc;
    overflow: hidden;
    box-shadow: 0 12px 36px rgba(16, 36, 48, 0.04);
    transition:
      border-color 0.45s ease,
      box-shadow 0.45s ease,
      transform 0.45s ease;
  }
  .process-step.is-active .process-step__media {
    border-color: rgba(78, 152, 198, 0.62);
    box-shadow: 0 18px 44px rgba(37, 90, 120, 0.12);
    transform: translateY(-2px);
  }
  .process-step__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  /* De brede monitoring-foto: laptop als focuspunt houden in de crop */
  .process-step--beheer .process-step__media img {
    object-position: 58% 50%;
  }
  .fx {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  /* Analyse: scan + focus targets */
  .fx-scan {
    position: absolute;
    left: 0;
    right: 0;
    top: -20%;
    height: 26%;
    opacity: 0;
    background: linear-gradient(
      180deg,
      transparent,
      rgba(108, 188, 235, 0.16),
      rgba(78, 152, 198, 0.52),
      transparent
    );
  }
  .process-step--analyse.is-active .fx-scan {
    animation: scanPass 1.55s cubic-bezier(0.22, 1, 0.36, 1) 0.15s 1;
  }
  .fx-target {
    position: absolute;
    width: 34px;
    height: 34px;
    border: 1.5px solid rgba(78, 152, 198, 0.8);
    border-radius: 50%;
    opacity: 0;
  }
  .fx-target::before,
  .fx-target::after {
    content: '';
    position: absolute;
    background: rgba(78, 152, 198, 0.7);
  }
  .fx-target::before {
    width: 12px;
    height: 1px;
    left: 10px;
    top: 16px;
  }
  .fx-target::after {
    width: 1px;
    height: 12px;
    left: 16px;
    top: 10px;
  }
  .fx-target--one {
    left: 58%;
    top: 28%;
  }
  .fx-target--two {
    left: 38%;
    top: 58%;
  }
  .process-step--analyse.is-active .fx-target {
    animation: targetPop 0.7s ease 0.75s forwards;
  }
  .process-step--analyse.is-active .fx-target--two {
    animation-delay: 1s;
  }

  /* Bekabeling: draw overlay path */
  .fx--cable {
    width: 100%;
    height: 100%;
  }
  .cable-shadow,
  .cable-line {
    fill: none;
    vector-effect: non-scaling-stroke;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 260;
    stroke-dashoffset: 260;
  }
  .cable-shadow {
    stroke: rgba(255, 255, 255, 0.88);
    stroke-width: 5.5;
  }
  .cable-line {
    stroke: #59aee0;
    stroke-width: 2.2;
    filter: drop-shadow(0 0 4px rgba(78, 152, 198, 0.45));
  }
  .process-step--bekabeling.is-active .cable-shadow,
  .process-step--bekabeling.is-active .cable-line {
    animation: drawCable 1.7s cubic-bezier(0.22, 1, 0.36, 1) 0.12s forwards;
  }

  /* Apparatuur: product boot + LEDs */
  .process-step--apparatuur .process-step__media img {
    transform: scale(0.96);
    filter: saturate(0.8) brightness(0.97);
    transition:
      transform 0.7s ease,
      filter 0.7s ease;
  }
  .process-step--apparatuur.is-active .process-step__media img {
    transform: scale(1);
    filter: saturate(1) brightness(1);
  }
  .led {
    position: absolute;
    bottom: 45%;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #79d3ff;
    opacity: 0;
    box-shadow: 0 0 9px #79d3ff;
  }
  .led--1 {
    left: 43%;
  }
  .led--2 {
    left: 47%;
  }
  .led--3 {
    left: 51%;
  }
  .led--4 {
    left: 55%;
  }
  .led--5 {
    left: 59%;
  }
  .led--6 {
    left: 63%;
  }
  .process-step--apparatuur.is-active .led {
    animation: ledBoot 0.55s ease forwards;
  }
  .process-step--apparatuur.is-active .led--2 {
    animation-delay: 0.1s;
  }
  .process-step--apparatuur.is-active .led--3 {
    animation-delay: 0.2s;
  }
  .process-step--apparatuur.is-active .led--4 {
    animation-delay: 0.3s;
  }
  .process-step--apparatuur.is-active .led--5 {
    animation-delay: 0.4s;
  }
  .process-step--apparatuur.is-active .led--6 {
    animation-delay: 0.5s;
  }

  /* Wifi: finite coverage ripples */
  .wifi-ring {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 36%;
    aspect-ratio: 1;
    border: 1.5px solid rgba(78, 152, 198, 0.7);
    border-radius: 50%;
    transform: translate(-50%, -50%) scale(0.45);
    opacity: 0;
  }
  .process-step--wifi.is-active .wifi-ring {
    animation: wifiRipple 1.8s cubic-bezier(0.2, 0.65, 0.3, 1) 1;
  }
  .process-step--wifi.is-active .wifi-ring--2 {
    animation-delay: 0.28s;
  }
  .process-step--wifi.is-active .wifi-ring--3 {
    animation-delay: 0.56s;
  }

  /* Beheer: dashboard sweep + online indicator */
  .screen-sweep {
    position: absolute;
    top: 0;
    bottom: 0;
    left: -55%;
    width: 34%;
    background: linear-gradient(
      100deg,
      transparent,
      rgba(255, 255, 255, 0.32),
      transparent
    );
    transform: skewX(-12deg);
    opacity: 0;
  }
  .process-step--beheer.is-active .screen-sweep {
    animation: screenSweep 1.35s ease 0.2s 1;
  }
  .online-dot {
    position: absolute;
    right: 10%;
    bottom: 12%;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #42b97b;
    opacity: 0;
    box-shadow: 0 0 0 0 rgba(66, 185, 123, 0.35);
  }
  .process-step--beheer.is-active .online-dot {
    animation: onlineIn 0.6s ease 0.85s forwards;
  }

  .process-step__status {
    display: flex;
    gap: 8px;
    align-items: center;
    margin: 12px 4px 0;
    font-family: var(--font-mono);
    color: var(--brand-strong);
    font-size: 12.5px;
    opacity: 0;
    transform: translateY(5px);
    transition:
      opacity 0.45s ease 0.35s,
      transform 0.45s ease 0.35s;
  }
  .process-step__status span {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--brand);
    box-shadow: 0 0 0 4px rgba(78, 152, 198, 0.1);
    flex: none;
  }
  .process-step.is-active .process-step__status {
    opacity: 1;
    transform: translateY(0);
  }

  .process-premium__final {
    margin: 34px auto 0;
    text-align: center;
    color: var(--muted);
    font-size: 16px;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.55s ease,
      transform 0.55s ease;
  }
  .process-premium__final strong {
    color: var(--ink);
    font-weight: 600;
  }
  .process-premium__final.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @keyframes dataPulse {
    0% {
      left: 0;
      opacity: 0;
    }
    8% {
      opacity: 1;
    }
    92% {
      opacity: 1;
    }
    100% {
      left: 100%;
      opacity: 0;
    }
  }
  @keyframes scanPass {
    0% {
      top: -24%;
      opacity: 0;
    }
    18% {
      opacity: 1;
    }
    82% {
      opacity: 1;
    }
    100% {
      top: 105%;
      opacity: 0;
    }
  }
  @keyframes targetPop {
    0% {
      opacity: 0;
      transform: scale(0.65);
    }
    65% {
      opacity: 1;
      transform: scale(1.08);
    }
    100% {
      opacity: 0.92;
      transform: scale(1);
    }
  }
  @keyframes drawCable {
    to {
      stroke-dashoffset: 0;
    }
  }
  @keyframes ledBoot {
    0% {
      opacity: 0;
      transform: scale(0.5);
    }
    55% {
      opacity: 1;
      transform: scale(1.35);
    }
    100% {
      opacity: 0.9;
      transform: scale(1);
    }
  }
  @keyframes wifiRipple {
    0% {
      opacity: 0;
      transform: translate(-50%, -50%) scale(0.38);
    }
    22% {
      opacity: 0.75;
    }
    100% {
      opacity: 0;
      transform: translate(-50%, -50%) scale(2.1);
    }
  }
  @keyframes screenSweep {
    0% {
      left: -55%;
      opacity: 0;
    }
    20% {
      opacity: 1;
    }
    100% {
      left: 125%;
      opacity: 0;
    }
  }
  @keyframes onlineIn {
    0% {
      opacity: 0;
      transform: scale(0.6);
      box-shadow: 0 0 0 0 rgba(66, 185, 123, 0.35);
    }
    65% {
      opacity: 1;
      transform: scale(1.15);
      box-shadow: 0 0 0 8px rgba(66, 185, 123, 0);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }

  @media (max-width: 980px) {
    .process-premium__timeline {
      display: none;
    }
    .process-premium__grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .process-step {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(240px, 0.9fr);
      gap: 18px;
      align-items: center;
      opacity: 1;
      transform: none;
    }
    .process-step__head {
      min-height: 0;
    }
    .process-step__status {
      grid-column: 2;
      margin-top: -8px;
      opacity: 1;
      transform: none;
    }
    .process-premium__final {
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 680px) {
    .process-premium__inner {
      width: min(100% - 28px, 1152px);
      padding: 42px 0 48px;
    }
    .process-step {
      display: block;
      padding-left: 14px;
      border-left: 2px solid var(--line);
    }
    .process-step.is-active {
      border-left-color: var(--brand);
    }
    .process-step__head {
      min-height: 0;
      margin-bottom: 12px;
    }
    .process-step__media {
      aspect-ratio: 16 / 10;
    }
    .process-step__status {
      margin: 10px 2px 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .process-premium *,
    .process-premium *::before,
    .process-premium *::after {
      animation-duration: 0.001ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.001ms !important;
    }
    .process-step {
      opacity: 1;
      transform: none;
    }
    .process-step__status,
    .process-premium__final {
      opacity: 1;
      transform: none;
    }
  }
</style>
