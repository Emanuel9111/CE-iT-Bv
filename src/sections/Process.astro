---
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';

/**
 * "Zo bouwen wij uw netwerk" — 5 stappen met illustratie en gestippelde
 * connectors (referentiestijl). Stappen activeren tijdens scroll
 * (04-ANIMATION-SPEC §5). Desktop: horizontaal, mobiel: verticale timeline.
 */
const steps = [
  {
    nr: '01',
    title: 'Analyse',
    text: 'We bekijken uw gebouw, uw infrastructuur en wat uw gebruikers nodig hebben.',
    icon: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="12" width="18" height="26" rx="2"/><path d="M13 18h3m-3 6h3m-3 6h3"/><circle cx="31" cy="27" r="8"/><path d="m37 33 5 5"/></svg>',
  },
  {
    nr: '02',
    title: 'Bekabeling',
    text: 'Professionele structurele bekabeling op de juiste plaatsen, in elke ruimte.',
    icon: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 38V16a6 6 0 0 1 6-6h4"/><path d="M16 38V20a4 4 0 0 1 4-4h2"/><rect x="26" y="8" width="12" height="10" rx="2"/><path d="M30 18v4m4-4v4"/><path d="M22 38h16"/></svg>',
  },
  {
    nr: '03',
    title: 'Apparatuur',
    text: 'We installeren en configureren gateway, switches en netwerkcomponenten.',
    icon: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="14" width="32" height="9" rx="2"/><rect x="8" y="27" width="32" height="9" rx="2"/><circle cx="14" cy="18.5" r="1.4" fill="currentColor"/><circle cx="14" cy="31.5" r="1.4" fill="currentColor"/><path d="M22 18.5h12m-12 13h12"/></svg>',
  },
  {
    nr: '04',
    title: 'Wifi',
    text: 'Access points op de juiste plaatsen voor stabiele en consistente dekking.',
    icon: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="24" cy="30" r="7"/><circle cx="24" cy="30" r="2" fill="currentColor"/><path d="M12 20a17 17 0 0 1 24 0"/><path d="M16.5 24.5a11 11 0 0 1 15 0"/></svg>',
  },
  {
    nr: '05',
    title: 'Beheer',
    text: 'We monitoren en beheren het netwerk op afstand en volgen snel op.',
    icon: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="10" y="12" width="28" height="18" rx="2"/><path d="M15 21h4l2-4 3 8 2.5-5H32"/><path d="M8 36h32"/></svg>',
  },
];
---

<Section id="werkwijze">
  <div class="reveal max-w-3xl">
    <Eyebrow>Van analyse tot beheer</Eyebrow>
    <h2
      class="mt-5 font-display text-[28px] font-semibold leading-tight tracking-tight text-ink-950 md:text-[34px]"
    >
      Zo bouwen wij uw netwerk.
    </h2>
    <p class="mt-4 max-w-2xl text-[16px] leading-relaxed text-ink-600">
      Eén duidelijk proces. Eén partner voor het volledige netwerk.
    </p>
  </div>

  <ol
    id="process-flow"
    class="process mt-14 grid gap-10 md:grid-cols-5 md:gap-6"
  >
    {
      steps.map((step) => (
        <li class="process-step relative pl-14 md:pl-0">
          <span class="connector" aria-hidden="true" />
          <div class="mb-2 flex items-center gap-2.5">
            <span
              class="dot font-mono absolute left-0 top-0 flex h-8 w-8 items-center justify-center rounded-full border border-teal-100 bg-teal-50 text-[11px] font-medium text-teal-600 transition-colors duration-300 md:static"
              aria-hidden="true"
            >
              {step.nr}
            </span>
            <h3 class="step-title font-display text-[17px] font-semibold tracking-tight text-ink-950">
              {step.title}
            </h3>
          </div>
          <p class="text-[13.5px] leading-relaxed text-ink-600">{step.text}</p>
          <div
            class="icon-box mt-5 flex h-24 w-full max-w-[150px] items-center justify-center rounded-lg border border-line bg-paper-25 text-teal-600 md:h-28 md:max-w-none"
            aria-hidden="true"
          >
            <span class="block h-12 w-12" set:html={step.icon} />
          </div>
        </li>
      ))
    }
  </ol>

  <div class="reveal mt-12 flex justify-center">
    <Button href="#contact" variant="secondary" arrow>
      Meer over onze werkwijze
    </Button>
  </div>
</Section>

<style>
  /* Gestippelde connectors */
  .process-step .connector {
    position: absolute;
  }
  /* Mobiel: verticale timeline links */
  @media (max-width: 767px) {
    .process-step .connector {
      left: 15px;
      top: 40px;
      bottom: -40px;
      border-left: 2px dashed var(--color-line);
    }
    .process-step:last-child .connector {
      display: none;
    }
  }
  /* Desktop: horizontale stippellijn ter hoogte van de illustraties */
  @media (min-width: 768px) {
    .process-step .connector {
      bottom: 56px;
      left: calc(100% - 4px);
      width: calc(24px + 8px);
      border-top: 2px dashed var(--color-line);
    }
    .process-step:last-child .connector {
      display: none;
    }
  }

  /* Actieve stap: chip vult teal, alles ervoor blijft rustig zichtbaar */
  .process-step.active .dot {
    border-color: var(--color-teal-600);
    background: var(--color-teal-600);
    color: var(--color-white);
  }
  @media (prefers-reduced-motion: reduce) {
    .process-step .dot {
      transition: none;
    }
  }
</style>

<script>
  const steps = document.querySelectorAll('#process-flow .process-step');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reduced || !('IntersectionObserver' in window)) {
    steps.forEach((el) => el.classList.add('active'));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
            io.unobserve(entry.target);
          }
        }
      },
      { rootMargin: '-20% 0px -20% 0px', threshold: 0 }
    );
    steps.forEach((el) => io.observe(el));
  }
</script>
