---
import fs from 'node:fs';
import path from 'node:path';
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';

/**
 * "Zo bouwen wij uw netwerk" — 5 stappen met beeld + scroll-activatie.
 * Per stap wordt de afbeelding getoond zodra het bestand bestaat in
 * /public/images/ (canonieke namen hieronder); tot dan een getekend icoon.
 * Connectors vullen zich progressief met teal wanneer een stap actief wordt.
 */
const stepData = [
  {
    nr: '01',
    title: 'Analyse',
    text: 'We bekijken uw gebouw, uw infrastructuur en wat uw gebruikers nodig hebben.',
    file: 'werkwijze-01-analyse.jpg',
    icon: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="12" width="18" height="26" rx="2"/><path d="M13 18h3m-3 6h3m-3 6h3"/><circle cx="31" cy="27" r="8"/><path d="m37 33 5 5"/></svg>',
  },
  {
    nr: '02',
    title: 'Bekabeling',
    text: 'Professionele structurele bekabeling op de juiste plaatsen, in elke ruimte.',
    file: 'werkwijze-02-bekabeling.jpg',
    icon: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 38V16a6 6 0 0 1 6-6h4"/><path d="M16 38V20a4 4 0 0 1 4-4h2"/><rect x="26" y="8" width="12" height="10" rx="2"/><path d="M30 18v4m4-4v4"/><path d="M22 38h16"/></svg>',
  },
  {
    nr: '03',
    title: 'Apparatuur',
    text: 'We installeren en configureren gateway, switches en netwerkcomponenten.',
    file: 'werkwijze-03-apparatuur.jpg',
    icon: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="14" width="32" height="9" rx="2"/><rect x="8" y="27" width="32" height="9" rx="2"/><circle cx="14" cy="18.5" r="1.4" fill="currentColor"/><circle cx="14" cy="31.5" r="1.4" fill="currentColor"/><path d="M22 18.5h12m-12 13h12"/></svg>',
  },
  {
    nr: '04',
    title: 'Wifi',
    text: 'Access points op de juiste plaatsen voor stabiele en consistente dekking.',
    file: 'werkwijze-04-wifi.jpg',
    icon: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="24" cy="30" r="7"/><circle cx="24" cy="30" r="2" fill="currentColor"/><path d="M12 20a17 17 0 0 1 24 0"/><path d="M16.5 24.5a11 11 0 0 1 15 0"/></svg>',
  },
  {
    nr: '05',
    title: 'Beheer',
    text: 'We monitoren en beheren het netwerk op afstand en volgen snel op.',
    file: 'werkwijze-05-beheer.jpg',
    icon: '<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="10" y="12" width="28" height="18" rx="2"/><path d="M15 21h4l2-4 3 8 2.5-5H32"/><path d="M8 36h32"/></svg>',
  },
];

const steps = stepData.map((s) => ({
  ...s,
  exists: fs.existsSync(path.join(process.cwd(), 'public', 'images', s.file)),
  src: `${import.meta.env.BASE_URL}images/${s.file}`,
}));
---

<Section id="werkwijze">
  <div class="reveal max-w-3xl">
    <Eyebrow>Van analyse tot beheer</Eyebrow>
    <h2
      class="mt-3 font-display text-[28px] font-semibold leading-tight tracking-tight text-ink-950 md:text-[34px]"
    >
      Zo bouwen wij uw netwerk.
    </h2>
    <p class="mt-3 max-w-2xl text-[15.5px] leading-relaxed text-ink-600">
      Eén duidelijk proces. Eén partner voor het volledige netwerk.
    </p>
  </div>

  <ol
    id="process-flow"
    class="process mt-8 grid gap-10 md:grid-cols-5 md:gap-6"
  >
    {
      steps.map((step) => (
        <li class="process-step relative pl-14 md:pl-0">
          <span class="connector" aria-hidden="true" />
          <div class="mb-2 flex items-center gap-2.5">
            <span
              class="dot font-mono absolute left-0 top-0 flex h-8 w-8 items-center justify-center rounded-full border border-brand-100 bg-brand-50 text-[11px] font-medium text-brand-600 transition-colors duration-300 md:static"
              aria-hidden="true"
            >
              {step.nr}
            </span>
            <h3 class="step-title font-display text-[17px] font-semibold tracking-tight text-ink-950">
              {step.title}
            </h3>
          </div>
          <p class="text-[13.5px] leading-relaxed text-ink-600">{step.text}</p>

          {step.exists ? (
            <img
              src={step.src}
              alt={`${step.title} — stap ${step.nr} van onze werkwijze`}
              loading="lazy"
              decoding="async"
              class="step-media mt-4 aspect-[4/3] w-full rounded-lg object-cover transition-shadow duration-300"
            />
          ) : (
            <div
              class="step-media mt-4 flex aspect-[4/3] w-full flex-col items-center justify-center gap-2 rounded-lg border border-line bg-paper-25 text-brand-600 transition-shadow duration-300"
              aria-hidden="true"
            >
              <span class="block h-12 w-12" set:html={step.icon} />
              <span class="px-3 text-center font-mono text-[10px] leading-tight text-ink-500">
                [{step.file}]
              </span>
            </div>
          )}
        </li>
      ))
    }
  </ol>

  <div class="reveal mt-8 flex justify-center">
    <Button href="#contact" variant="secondary" arrow>
      Meer over onze werkwijze
    </Button>
  </div>
</Section>

<style>
  /* Connector: gestippelde basis + teal vulling die zich progressief vult */
  .process-step .connector {
    position: absolute;
  }
  @media (max-width: 767px) {
    .process-step .connector {
      left: 15px;
      top: 40px;
      bottom: -40px;
      border-left: 2px dashed var(--color-line);
    }
    .process-step:last-child .connector {
      display: none;
    }
  }
  @media (min-width: 768px) {
    .process-step .connector {
      top: 15px;
      left: calc(100% - 8px);
      width: calc(100% * 0.12 + 24px);
      border-top: 2px dashed var(--color-line);
    }
    .process-step:last-child .connector {
      display: none;
    }
  }
  .process-step .connector::after {
    content: '';
    position: absolute;
    background: var(--color-brand-500);
  }
  @media (max-width: 767px) {
    .process-step .connector::after {
      left: -2px;
      top: 0;
      bottom: 0;
      width: 2px;
      transform: scaleY(0);
      transform-origin: top;
      transition: transform 0.6s ease-out 0.15s;
    }
  }
  @media (min-width: 768px) {
    .process-step .connector::after {
      top: -2px;
      left: 0;
      right: 0;
      height: 2px;
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.6s ease-out 0.15s;
    }
  }

  /* Actieve stap: badge vult, beeld krijgt accent */
  .process-step.active .dot {
    border-color: var(--color-brand-600);
    background: var(--color-brand-600);
    color: var(--color-white);
  }
  .process-step.active .connector::after {
    transform: none;
  }
  .process-step.active .step-media {
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--color-brand-500) 45%, transparent),
      0 10px 30px -12px rgba(10, 22, 32, 0.18);
  }

  @media (prefers-reduced-motion: reduce) {
    .process-step .connector::after,
    .process-step .dot,
    .process-step .step-media {
      transition: none;
    }
  }
</style>

<script>
  const steps = document.querySelectorAll('#process-flow .process-step');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reduced || !('IntersectionObserver' in window)) {
    steps.forEach((el) => el.classList.add('active'));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
            io.unobserve(entry.target);
          }
        }
      },
      { rootMargin: '-15% 0px -15% 0px', threshold: 0 }
    );
    steps.forEach((el) => io.observe(el));
  }
</script>
